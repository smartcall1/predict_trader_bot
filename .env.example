# =============================================
# Predict.fun 봇 환경변수 설정
# 이 파일을 .env 로 복사 후 실제 값 입력
# =============================================

# === Predict.fun API (Discord에서 발급) ===
PREDICT_API_KEY=

# === BNB Chain 지갑 ===
PRIVATE_KEY=0x개인키_절대_공유_금지
WALLET_ADDRESS=0x지갑주소

# BSC RPC (기본값 사용 권장, 막힐 경우 교체)
# BSC_RPC_URL=https://bsc-dataseed1.binance.org

# === 운영 설정 ===
# 초기 USDT 잔고 (ROI 계산 기준, state 파일 없을 때만 사용)
INITIAL_BANKROLL=1000.0
# True=페이퍼, False=실거래
PAPER_TRADING=True
DEBUG_MODE=True

# === 봇 파라미터 ===
MAX_POSITIONS=20
# 포트폴리오 / BET_DIVISOR = 1회 베팅금
BET_DIVISOR=20
STOP_LOSS_PCT=0.40
# 이 금액 이상 거래만 고래로 인식
MIN_WHALE_SIZE_USDT=500.0
# 슬리피지 허용 bps (300=3%)
DEFAULT_SLIPPAGE_BPS=300
# 극초저확률 차단
MIN_PRICE=0.10
# 0.85 초과 = 정산 직전 고위험 마켓 차단
MAX_PRICE=0.85

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
